# Variables de entorno para Slide Battle
# Copiar este archivo a server/.env y configurar en Render

# ===========================================
# AUTENTICACIÓN
# ===========================================
# Cambia estas credenciales en producción
JUEZ1_USER=Slide
JUEZ1_PASS=slide2026

JUEZ2_USER=juez2
JUEZ2_PASS=slide

JUEZ3_USER=juez3
JUEZ3_PASS=slide

# ===========================================
# CONFIGURACIÓN DEL SERVIDOR
# ===========================================
NODE_ENV=production
PORT=3005

# ===========================================
# SEGURIDAD - CORS
# ===========================================
# Reemplaza con tu dominio real en producción
# Ejemplo: https://slide-battle.onrender.com
CORS_ORIGIN=http://localhost:3005

# ===========================================
# BASE DE DATOS - Supabase (PostgreSQL)
# ===========================================
